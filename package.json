{
  "name": "cadastro-de-pets",
  "description": "API REST para cadastro de usuários e pets, com autenticação JWT e documentação Swagger.",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npm run test-rest-controller && npm run test-rest-external",
    "start-rest": "node rest/server.js",
    "test-rest-external": "mocha test/rest/external/*.test.js --timeout 10000 --reporter mochawesome",
    "test-rest-controller": "mocha test/rest/controller/*.test.js --timeout 10000 --reporter mochawesome",
    "start": "node rest/server.js"
  },
  "author": "Tiago Andrade",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "chai": "4.5.0",
    "chai-exclude": "^2.1.1",
    "dotenv": "^17.2.2",
    "mocha": "^11.7.6",
    "mochawesome": "^7.1.4",
    "sinon": "^21.0.0",
    "supertest": "^7.1.4"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5",
    "uuid": "^11.1.0"
  }
}
